<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>SPORT STORE</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: #111;
      color: white;
      text-align: center;
    }

    /* CABECERA (SE MANTIENE COMO ANTES) */
    .header {
      background: url('https://images.unsplash.com/photo-1517836357463-d25dfeac3438') center/cover;
      height: 250px;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header-content {
      background: rgba(0,0,0,0.6);
      padding: 15px 25px;
      border-radius: 10px;
    }

    h1 {
      margin: 0;
      font-size: 32px;
      letter-spacing: 2px;
    }

    h2 {
      margin-top: 10px;
      font-size: 20px;
    }

    /* ZONA DONDE IRÁN TUS IFRAMES */
    .contenido {
      background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
      padding: 40px 20px;
      min-height: 400px;
    }

  </style>
</head>
<body>

<div class="header">
  <div class="header-content">
    <h1>SPORT STORE</h1>
    <h2>Tu estilo empieza aquí</h2>
  </div>
</div>

<div class="contenido">

  <!-- 🔻 PEGA AQUÍ TUS IFRAMES / CATÁLOGO 🔻 -->
  <!-- EJEMPLO:
  <iframe src="TU_LINK" width="100%" height="500"></iframe>
  -->

</div>

</body>
</html>
